{
  "name": "zendocs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 portless zendocs bun run dev:app --force",
    "dev:app": "vite --host 127.0.0.1 --port ${PORT:-3140}",
    "build": "vite build",
    "serve": "NODE_ENV=production bun scripts/serve.mjs",
    "start": "bun run serve",
    "docker:up": "docker compose up -d --build --force-recreate && PORTLESS_PORT=1355 PORTLESS_HTTPS=0 portless alias zendocs ${ZENDOCS_PORT:-1356} --force",
    "docker:alias": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 portless alias zendocs ${ZENDOCS_PORT:-1356} --force",
    "docker:down": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 portless alias --remove zendocs || true; docker compose down",
    "docker:logs": "docker compose logs -f zendocs"
  },
  "portless": {
    "name": "zendocs",
    "script": "dev:app"
  },
  "dependencies": {
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-start": "latest",
    "@vitejs/plugin-react": "^5.1.1",
    "chokidar": "^3.6.0",
    "fumadocs-core": "latest",
    "fumadocs-ui": "latest",
    "marked": "latest",
    "mermaid": "^11.15.0",
    "react": "latest",
    "react-dom": "latest",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "portless": "^0.13.0",
    "typescript": "latest"
  }
}
